[
 {
  "doctype": "AK Document Template",
  "name": "Sales Order Approval",
  "template_name": "Sales Order Approval",
  "reference_doctype": "Sales Order",
  "is_active": 1,
  "is_public_form": 0,
  "expires_in_days": 7,
  "track_opens": 1,
  "show_accept_decline": 1,
  "lock_after_submission": 1,
  "disable_access_after_submission": 0,
  "notify_on_view": 0,
  "notify_on_response": 1,
  "reminder_days": 2,
  "success_message": "Thank you! Your response has been recorded.",
  "page_format": "A4",
  "top_margin": 15,
  "bottom_margin": 15,
  "left_margin": 15,
  "right_margin": 15,
  "email_subject": "Action Required: Sales Order {{ doc.name }} — {{ doc.customer_name }}",
  "email_body_html": "<p>Dear {{ doc.contact_person or doc.customer_name }},</p>\n<p>Please review and approve the attached Sales Order <strong>{{ doc.name }}</strong>.</p>\n<p><a href=\"{{ share_url }}\" style=\"background:#4f46e5;color:#fff;padding:10px 20px;border-radius:6px;text-decoration:none;display:inline-block;\">Review &amp; Approve</a></p>\n<p>This link expires in 7 days.</p>",
  "attach_pdf": 0,
  "auto_send_on": "",
  "auto_send_to_field": "",
  "template_html": "<div style=\"font-family: 'Segoe UI', Arial, sans-serif; max-width: 760px; margin: 0 auto; color: #1e293b;\">\n\n  <!-- Header -->\n  <div style=\"background: #4f46e5; color: white; padding: 32px 40px; border-radius: 8px 8px 0 0;\">\n    <div style=\"display: flex; justify-content: space-between; align-items: flex-start;\">\n      <div>\n        <h1 style=\"margin: 0 0 4px 0; font-size: 24px; font-weight: 700;\">Sales Order</h1>\n        <p style=\"margin: 0; opacity: 0.85; font-size: 15px;\">{{ doc.name }}</p>\n      </div>\n      <div style=\"text-align: right;\">\n        <span style=\"background: rgba(255,255,255,0.2); padding: 4px 12px; border-radius: 20px; font-size: 13px;\">{{ doc.status }}</span>\n        <p style=\"margin: 8px 0 0 0; opacity: 0.85; font-size: 13px;\">{{ frappe.utils.formatdate(doc.transaction_date) }}</p>\n      </div>\n    </div>\n  </div>\n\n  <!-- Body -->\n  <div style=\"background: #fff; padding: 32px 40px; border: 1px solid #e2e8f0; border-top: none;\">\n\n    <!-- Customer & Delivery -->\n    <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 28px;\">\n      <div>\n        <p style=\"margin: 0 0 4px 0; font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: #64748b;\">Customer</p>\n        <p style=\"margin: 0; font-size: 16px; font-weight: 600;\">{{ doc.customer_name }}</p>\n        {% if doc.customer_address %}\n        <p style=\"margin: 4px 0 0 0; font-size: 13px; color: #64748b;\">{{ doc.customer_address }}</p>\n        {% endif %}\n      </div>\n      <div>\n        <p style=\"margin: 0 0 4px 0; font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: #64748b;\">Delivery Date</p>\n        <p style=\"margin: 0; font-size: 16px; font-weight: 600;\">{{ frappe.utils.formatdate(doc.delivery_date) if doc.delivery_date else '—' }}</p>\n        {% if doc.po_no %}\n        <p style=\"margin: 4px 0 0 0; font-size: 13px; color: #64748b;\">PO: {{ doc.po_no }}</p>\n        {% endif %}\n      </div>\n    </div>\n\n    <!-- Items Table -->\n    <table style=\"width: 100%; border-collapse: collapse; margin-bottom: 24px;\">\n      <thead>\n        <tr style=\"background: #f8fafc;\">\n          <th style=\"padding: 10px 12px; text-align: left; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; border-bottom: 2px solid #e2e8f0;\">#</th>\n          <th style=\"padding: 10px 12px; text-align: left; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; border-bottom: 2px solid #e2e8f0;\">Item</th>\n          <th style=\"padding: 10px 12px; text-align: right; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; border-bottom: 2px solid #e2e8f0;\">Qty</th>\n          <th style=\"padding: 10px 12px; text-align: right; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; border-bottom: 2px solid #e2e8f0;\">Rate</th>\n          <th style=\"padding: 10px 12px; text-align: right; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; border-bottom: 2px solid #e2e8f0;\">Amount</th>\n        </tr>\n      </thead>\n      <tbody>\n        {% for item in doc.items %}\n        <tr style=\"border-bottom: 1px solid #f1f5f9;\">\n          <td style=\"padding: 10px 12px; font-size: 13px; color: #94a3b8;\">{{ loop.index }}</td>\n          <td style=\"padding: 10px 12px;\">\n            <p style=\"margin: 0; font-size: 14px; font-weight: 500;\">{{ item.item_name }}</p>\n            {% if item.description %}\n            <p style=\"margin: 2px 0 0 0; font-size: 12px; color: #64748b;\">{{ item.description[:80] }}</p>\n            {% endif %}\n          </td>\n          <td style=\"padding: 10px 12px; text-align: right; font-size: 14px;\">{{ item.qty }} {{ item.uom }}</td>\n          <td style=\"padding: 10px 12px; text-align: right; font-size: 14px;\">{{ frappe.utils.fmt_money(item.rate, currency=doc.currency) }}</td>\n          <td style=\"padding: 10px 12px; text-align: right; font-size: 14px; font-weight: 500;\">{{ frappe.utils.fmt_money(item.amount, currency=doc.currency) }}</td>\n        </tr>\n        {% endfor %}\n      </tbody>\n      <tfoot>\n        {% if doc.discount_amount %}\n        <tr>\n          <td colspan=\"4\" style=\"padding: 8px 12px; text-align: right; font-size: 13px; color: #64748b;\">Discount</td>\n          <td style=\"padding: 8px 12px; text-align: right; font-size: 13px; color: #ef4444;\">-{{ frappe.utils.fmt_money(doc.discount_amount, currency=doc.currency) }}</td>\n        </tr>\n        {% endif %}\n        {% if doc.total_taxes_and_charges %}\n        <tr>\n          <td colspan=\"4\" style=\"padding: 8px 12px; text-align: right; font-size: 13px; color: #64748b;\">Taxes</td>\n          <td style=\"padding: 8px 12px; text-align: right; font-size: 13px;\">{{ frappe.utils.fmt_money(doc.total_taxes_and_charges, currency=doc.currency) }}</td>\n        </tr>\n        {% endif %}\n        <tr style=\"background: #f8fafc;\">\n          <td colspan=\"4\" style=\"padding: 12px; text-align: right; font-size: 15px; font-weight: 700;\">Total</td>\n          <td style=\"padding: 12px; text-align: right; font-size: 18px; font-weight: 700; color: #4f46e5;\">{{ frappe.utils.fmt_money(doc.grand_total, currency=doc.currency) }}</td>\n        </tr>\n      </tfoot>\n    </table>\n\n    {% if doc.terms %}\n    <div style=\"background: #f8fafc; border-left: 3px solid #e2e8f0; padding: 12px 16px; border-radius: 0 6px 6px 0; margin-bottom: 28px;\">\n      <p style=\"margin: 0 0 4px 0; font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: #64748b;\">Terms &amp; Conditions</p>\n      <p style=\"margin: 0; font-size: 13px; color: #475569;\">{{ doc.terms }}</p>\n    </div>\n    {% endif %}\n\n    <!-- Interactive: Approver Name & Comments -->\n    <div style=\"background: #f0f9ff; border: 1px solid #bae6fd; border-radius: 8px; padding: 24px; margin-bottom: 24px;\">\n      <h3 style=\"margin: 0 0 16px 0; font-size: 15px; font-weight: 600; color: #0369a1;\">Your Approval</h3>\n      <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: 16px;\">\n        <div>\n          {{ ak_input('approver_name', 'Full Name', mandatory=True) }}\n        </div>\n        <div>\n          {{ ak_input('approver_title', 'Title / Position') }}\n        </div>\n      </div>\n      <div style=\"margin-top: 16px;\">\n        {{ ak_textarea('comments', 'Comments (optional)') }}\n      </div>\n    </div>\n\n    {{ ak_accept_decline() }}\n\n  </div>\n\n  <!-- Footer -->\n  <div style=\"background: #f8fafc; padding: 16px 40px; border: 1px solid #e2e8f0; border-top: none; border-radius: 0 0 8px 8px; text-align: center;\">\n    <p style=\"margin: 0; font-size: 12px; color: #94a3b8;\">This document was sent securely. This link expires on {{ frappe.utils.formatdate(share.expires_at) if share.expires_at else 'N/A' }}.</p>\n  </div>\n\n</div>",
  "custom_css": ".ak-field { margin-bottom: 12px; }\n.ak-field-label { text-transform: uppercase; letter-spacing: 0.05em; color: #475569; }\n.ak-field-input { border-color: #cbd5e1; }\n.ak-field-input:focus { border-color: #4f46e5; box-shadow: 0 0 0 3px rgba(79,70,229,0.1); }\n.ak-accept-btn { background: #22c55e; }\n.ak-accept-btn:hover { background: #16a34a; }\n.ak-decline-btn { color: #ef4444; border-color: #ef4444; }\n.ak-decline-btn:hover { background: #fef2f2; }",
  "fields": [
   {
    "doctype": "AK Template Field",
    "field_name": "approver_name",
    "field_label": "Full Name",
    "field_type": "Data",
    "is_existing_field": 0,
    "is_editable": 1,
    "is_mandatory": 1,
    "column": "Left"
   },
   {
    "doctype": "AK Template Field",
    "field_name": "approver_title",
    "field_label": "Title / Position",
    "field_type": "Data",
    "is_existing_field": 0,
    "is_editable": 1,
    "is_mandatory": 0,
    "column": "Right"
   },
   {
    "doctype": "AK Template Field",
    "field_name": "comments",
    "field_label": "Comments",
    "field_type": "Text",
    "is_existing_field": 0,
    "is_editable": 1,
    "is_mandatory": 0,
    "column": "Full Width"
   }
  ]
 }
]
